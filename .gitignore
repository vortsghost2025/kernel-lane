# Ignore build outputs and local profiler caches
build/
*.obj
*.o
*.pdb
*.exe
*.dll
*.so
*.dylib
*.ptx
*.cubin
*.nvvp
*.nsys-rep
*.qdrep
*.sqlite
*.ncu-rep
*.ncu-rep.gz
*.log
*.bak
nul

# Keep release evidence and reports tracked
!releases/
!benchmarks/reports/
!profiles/

# Cryptographic material — never commit signatures or keys
*.jws
*.pem
.identity/
.runtime/

# Signed message sidecars (JWS signatures stored separately)
lanes/**/signature-*.jws

# Local operational files
lanes/*/outbox/unsigned/
logs/quarantine-tracker.json
